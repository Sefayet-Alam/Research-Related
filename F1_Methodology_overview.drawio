        </mxCell>
        <mxCell id="cEcDTE5n0xchJvEeUfNp-57" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9822b;strokeColor=#d9822b;fontColor=#ffffff;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;arcSize=10;" value="5 · Evaluation suite" vertex="1">
