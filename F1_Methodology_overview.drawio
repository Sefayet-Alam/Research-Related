        <mxCell id="cEcDTE5n0xchJvEeUfNp-48" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#111111;" value="Methodology overview: leakage-controlled reproduction and adversarially robust extension of the Ben-Sarc benchmark" vertex="1">
          <mxGeometry height="40" width="1520" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="cEcDTE5n0xchJvEeUfNp-49" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1f6feb;strokeColor=#1f6feb;fontColor=#ffffff;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;arcSize=10;" value="1 · Data foundation" vertex="1">
          <mxGeometry height="44" width="270" x="40" y="90" as="geometry" />
        </mxCell>
        <mxCell id="cEcDTE5n0xchJvEeUfNp-50" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e7f0fd;strokeColor=#1f6feb;fontColor=#13315c;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=8;arcSize=4;" value="&lt;b&gt;3 Bengali sarcasm corpora&lt;/b&gt;&lt;br&gt;Ben-Sarc · BanglaSarc · BanglaSarc3&lt;br&gt;&lt;br&gt;• Text normalization&lt;br&gt;• De-duplicate &lt;i&gt;before&lt;/i&gt; splitting&lt;br&gt;• Drop label-conflict rows&lt;br&gt;• Stratified 80 / 10 / 10&lt;br&gt;• Hard leakage assertion&lt;br&gt;&lt;br&gt;&lt;b&gt;4 task variants&lt;/b&gt;&lt;br&gt;3 binary + 1 ternary" vertex="1">
          <mxGeometry height="400" width="270" x="40" y="134" as="geometry" />
        </mxCell>
        <mxCell id="cEcDTE5n0xchJvEeUfNp-51" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0e7c86;strokeColor=#0e7c86;fontColor=#ffffff;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;arcSize=10;" value="2 · Reproduction (Lora et al.)" vertex="1">
          <mxGeometry height="44" width="270" x="350" y="90" as="geometry" />
        </mxCell>
        <mxCell id="cEcDTE5n0xchJvEeUfNp-52" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f3f5;strokeColor=#0e7c86;fontColor=#0b3a3f;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=8;arcSize=4;" value="&lt;b&gt;Faithful baselines on clean splits&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Classical ML × 7&lt;br&gt;  NB · SVM · LR · RF · DT · KNN&lt;br&gt;• Deep learning&lt;br&gt;  LSTM · CNN · GloVe · BiLSTM&lt;br&gt;• Frozen transfer&lt;br&gt;  Bengali-BERT · mBERT · sagorsarker&lt;br&gt;&lt;br&gt;&lt;b&gt;Reproduces best within ~1 pt&lt;/b&gt;&lt;br&gt;0.744 vs 0.755 macro-F1" vertex="1">
          <mxGeometry height="400" width="270" x="350" y="134" as="geometry" />
        </mxCell>
        <mxCell id="cEcDTE5n0xchJvEeUfNp-53" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e8b57;strokeColor=#2e8b57;fontColor=#ffffff;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;arcSize=10;" value="3 · Proposed AR-BanglaBERT" vertex="1">
          <mxGeometry height="44" width="270" x="660" y="90" as="geometry" />
        </mxCell>
        <mxCell id="cEcDTE5n0xchJvEeUfNp-54" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f4ec;strokeColor=#2e8b57;fontColor=#16432b;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=8;arcSize=4;" value="&lt;b&gt;Systematic build-up&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 5 backbones (full fine-tune)&lt;br&gt;• 4 adversarial schemes&lt;br&gt;  FGM · FreeLB · AWP · FGM+AWP&lt;br&gt;• 9-config pipeline search&lt;br&gt;• FGM ε-sweep → ε = 0.5&lt;br&gt;• 5-seed stability&lt;br&gt;&lt;br&gt;&lt;b&gt;AR-BanglaBERT&lt;/b&gt;&lt;br&gt;FGM+AWP · LLRD · label smoothing&lt;br&gt;dual-pool ([CLS]+mean) head" vertex="1">
          <mxGeometry height="400" width="270" x="660" y="134" as="geometry" />
        </mxCell>
        <mxCell id="cEcDTE5n0xchJvEeUfNp-55" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6f42c1;strokeColor=#6f42c1;fontColor=#ffffff;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;arcSize=10;" value="4 · Ensembling" vertex="1">
          <mxGeometry height="44" width="270" x="970" y="90" as="geometry" />
        </mxCell>
        <mxCell id="cEcDTE5n0xchJvEeUfNp-56" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#efe9f9;strokeColor=#6f42c1;fontColor=#36205e;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=8;arcSize=4;" value="&lt;b&gt;Combine the model zoo&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Soft voting&lt;br&gt;• Hard voting&lt;br&gt;• Top-K voting&lt;br&gt;• &lt;b&gt;Stacking (LR meta-learner)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Best overall number (0.812)&lt;br&gt;&lt;br&gt;&lt;i&gt;Honest note:&lt;/i&gt; gain over best&lt;br&gt;single model is small and&lt;br&gt;not statistically significant" vertex="1">
